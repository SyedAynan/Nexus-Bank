# ═══════════════════════════════════════════
# NEXUS Bank — .gitignore
# ═══════════════════════════════════════════

# ── Python ──
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
*.egg

# ── Virtual Environments ──
.venv/
venv/
env/
Include/
Lib/
Scripts/
scripts/*.exe

# ── Node ──
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build Outputs ──
dist/
build/
frontend/dist/

# ── Environment & Secrets ──
.env
.env.local
.env.*
!.env.example
!.env.production

# ── Databases ──
*.db
*.sqlite3

# ── Testing ──
.pytest_cache/
htmlcov/
.coverage
test.db

# ── IDE ──
.vscode/
.idea/
*.swp
*.swo

# ── OS Files ──
desktop.ini
Thumbs.db
.DS_Store

# ── Logs ──
*.log

# ── Archives ──
*.zip

# ── Temporary Files ──
*.tmp
*.temp
.cache/

# ── Tool-Generated ──
antigravity/
