# ============================================================
# NEXA v4.0 — Environment Configuration Template
# ============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit the .env file to version control.
# ============================================================

# ── Application ──
ENVIRONMENT=development          # development | staging | production
DEBUG=true                       # Set to false in production

# ── Security (CRITICAL — change in production!) ──
# Generate a secure key: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=CHANGE_ME_TO_A_RANDOM_64_CHAR_STRING

# ── Database ──
# Local SQLite (development):
DATABASE_URL=sqlite:///./nexa.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://nexa:YOUR_SECURE_PASSWORD@localhost:5432/nexa

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── JWT Token Configuration ──
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRES_MINUTES=30
REFRESH_TOKEN_EXPIRES_MINUTES=10080   # 7 days

# RS256 Asymmetric JWT (production — more secure than HS256)
# Generate keys:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
JWT_PRIVATE_KEY_PATH=
JWT_PUBLIC_KEY_PATH=

# ── Neo4j (AML Graph Database) ──
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=nexa_graph_2026

# ── Event Bus ──
EVENT_BUS_MODE=in-process         # in-process | kafka
KAFKA_BOOTSTRAP_SERVERS=          # kafka:9092 (when using Kafka)

# ── ML Fraud Engine ──
ML_MODEL_DIR=bank_system/ml_models
FRAUD_ENSEMBLE_WEIGHTS=0.35,0.35,0.30   # rules, isolation_forest, gbt

# ── Rate Limiting ──
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_BURST=20

# ── Docker PostgreSQL ──
POSTGRES_DB=nexa
POSTGRES_USER=nexa
POSTGRES_PASSWORD=CHANGE_ME_TO_SECURE_PASSWORD

# ── Frontend ──
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
FRONTEND_URL=

